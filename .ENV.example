# Vesper Environment Variables Template
# Copy this file to .ENV and fill in your actual keys.

# Groq API Keys for Free Tier Rotation
VESPER_GROQ_KEY_1=gsk_your_key_here_1
VESPER_GROQ_KEY_2=gsk_your_key_here_2
VESPER_GROQ_KEY_3=gsk_your_key_here_3

# Cloudflare Workers AI Configuration
VESPER_CF_KEY=cfk_your_key_here
VESPER_CF_ID=your_cloudflare_account_id_here

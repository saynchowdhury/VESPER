# Vesper Environment Variables
# Copy this file to .ENV and fill in the values

# Cloudflare Configuration
VESPER_CF_ID=your_cloudflare_account_id
VESPER_CF_KEY=your_cloudflare_api_key

# Groq API Keys (for rotation)
VESPER_GROQ_KEY_1=your_groq_api_key_1
VESPER_GROQ_KEY_2=your_groq_api_key_2
VESPER_GROQ_KEY_3=your_groq_api_key_3
